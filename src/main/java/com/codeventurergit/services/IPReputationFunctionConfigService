package com.codeventurergit.services;

import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;

import java.util.function.Function;

@Configuration
public class IPReputationFunctionConfigService {

    @Bean
    public Function<IPReputationRequestService, IPReputationResponseService> lookup() {
        return request -> {
            // TODO: Replace with DynamoDB lookup
            return new IpResponse(request.getIp(), "unknown");
        };
    }
}
